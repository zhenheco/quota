---
import Base from '../../layouts/Base.astro';
import { createClient, deleteClient, listClients, updateClient } from '../../server/clients-service';
import { runtimeEnv } from '../../server/runtime-env';
import { actionFromForm, clientInputFromForm, clientPatchFromForm, formId } from '../../server/ui-forms';

const env = runtimeEnv(Astro.locals);
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = actionFromForm(data);
    const id = formId(data);

    if (action === 'create') {
      await createClient(env, clientInputFromForm(data));
      return Astro.redirect('/clients');
    }

    if (action === 'update' && id !== null) {
      await updateClient(env, id, clientPatchFromForm(data));
      return Astro.redirect('/clients');
    }

    if (action === 'delete' && id !== null) {
      await deleteClient(env, id);
      return Astro.redirect('/clients');
    }

    error = '無法處理客戶資料。';
  } catch (clientError) {
    console.error(clientError);
    error = '無法處理客戶資料。';
  }
}

const clients = await listClients(env);
---

<Base title="客戶 | Quota">
  <main class="page">
    <header class="page-header">
      <div>
        <p class="eyebrow">CLIENTS</p>
        <h1>客戶管理</h1>
      </div>
    </header>

    {error && <p class="status-pill">{error}</p>}

    <section class="panel">
      <h2>新增客戶</h2>
      <form class="form-grid" method="POST">
        <input type="hidden" name="action" value="create" />
        <div class="field"><label>名稱</label><input name="name" required /></div>
        <div class="field"><label>聯絡人</label><input name="contact" /></div>
        <div class="field"><label>電話</label><input name="phone" /></div>
        <div class="field"><label>Email</label><input name="email" type="email" /></div>
        <div class="field field--wide"><label>地址</label><input name="address" /></div>
        <div class="field"><button type="submit">新增</button></div>
      </form>
    </section>

    <section class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>名稱</th>
            <th>聯絡人</th>
            <th>電話</th>
            <th>Email</th>
            <th>地址</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          {
            clients.map((client) => (
              <tr>
                <td colspan="6">
                  <form class="form-grid" method="POST">
                    <input type="hidden" name="action" value="update" />
                    <input type="hidden" name="id" value={client.id} />
                    <div class="field"><label>名稱</label><input name="name" value={client.name} required /></div>
                    <div class="field"><label>聯絡人</label><input name="contact" value={client.contact ?? ''} /></div>
                    <div class="field"><label>電話</label><input name="phone" value={client.phone ?? ''} /></div>
                    <div class="field"><label>Email</label><input name="email" type="email" value={client.email ?? ''} /></div>
                    <div class="field field--wide"><label>地址</label><input name="address" value={client.address ?? ''} /></div>
                    <div class="row-actions">
                      <button type="submit">儲存</button>
                      <button class="button--danger" type="submit" name="action" value="delete">刪除</button>
                    </div>
                  </form>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>
  </main>
</Base>
