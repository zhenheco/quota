---
import Base from '../../layouts/Base.astro';
import { putBrandAsset } from '../../server/brand';
import { getCompany, updateCompany } from '../../server/company-service';
import { runtimeEnv } from '../../server/runtime-env';
import { companyPatchFromForm } from '../../server/ui-forms';

const env = runtimeEnv(Astro.locals);
let company = await getCompany(env);
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const patch = companyPatchFromForm(data);

    for (const field of ['logo', 'stamp', 'bank_image'] as const) {
      const file = data.get(field);

      if (file instanceof File && file.size > 0) {
        const extension = file.name.split('.').pop()?.toLowerCase() || 'bin';
        const key = `brand/${field}-${Date.now()}.${extension}`;

        await putBrandAsset(env, key, await file.arrayBuffer(), file.type || 'application/octet-stream');

        if (field === 'logo') {
          patch.logo_key = key;
        } else if (field === 'stamp') {
          patch.stamp_key = key;
        } else {
          patch.bank_image_key = key;
        }
      }
    }

    company = await updateCompany(env, patch);
    return Astro.redirect('/settings');
  } catch (settingsError) {
    console.error(settingsError);
    error = '無法儲存設定。';
  }
}
---

<Base title="設定 | Quota">
  <main class="page">
    <header class="page-header">
      <div>
        <p class="eyebrow">SETTINGS</p>
        <h1>公司設定</h1>
      </div>
    </header>

    {error && <p class="status-pill">{error}</p>}

    <form class="panel form-grid" method="POST" enctype="multipart/form-data">
      <div class="field">
        <label for="name">公司名稱</label>
        <input id="name" name="name" value={company.name} required />
      </div>
      <div class="field">
        <label for="phone">電話</label>
        <input id="phone" name="phone" value={company.phone ?? ''} />
      </div>
      <div class="field field--wide">
        <label for="address">地址</label>
        <input id="address" name="address" value={company.address ?? ''} />
      </div>
      <div class="field field--wide">
        <label for="bank_info">匯款資訊</label>
        <textarea id="bank_info" name="bank_info">{company.bank_info ?? ''}</textarea>
      </div>
      <div class="field">
        <label for="default_tax_rate">預設稅率</label>
        <input id="default_tax_rate" name="default_tax_rate" type="number" min="0" max="1" step="0.01" value={company.default_tax_rate} />
      </div>
      <div class="field field--wide">
        <label for="default_notes">預設備註</label>
        <textarea id="default_notes" name="default_notes">{company.default_notes ?? ''}</textarea>
      </div>
      <div class="field">
        <label for="logo">品牌 Logo</label>
        <input id="logo" name="logo" type="file" accept="image/*" />
        {company.logo_key && <span class="muted">{company.logo_key}</span>}
      </div>
      <div class="field">
        <label for="stamp">公司章</label>
        <input id="stamp" name="stamp" type="file" accept="image/*" />
        {company.stamp_key && <span class="muted">{company.stamp_key}</span>}
      </div>
      <div class="field">
        <label for="bank_image">匯款圖</label>
        <input id="bank_image" name="bank_image" type="file" accept="image/*" />
        {company.bank_image_key && <span class="muted">{company.bank_image_key}</span>}
      </div>
      <div class="field field--wide">
        <button type="submit">儲存設定</button>
      </div>
    </form>
  </main>
</Base>
