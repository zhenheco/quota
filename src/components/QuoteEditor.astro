---
import QuoteDocument from './QuoteDocument.astro';
import type { Client, Company, Quote } from '../server/types';

interface Props {
  quote: Quote;
  company: Company;
  clients: Client[];
  submitLabel: string;
  error?: string;
}

const { quote, company, clients, submitLabel, error } = Astro.props;
---

<div class="grid-two" data-quote-editor>
  <form class="panel quote-editor editor-form" method="POST">
    {error && <p class="status-pill">{error}</p>}
    <section class="form-grid">
      <div class="field">
        <label for="client_id">既有客戶</label>
        <select id="client_id" name="client_id">
          <option value="">手動輸入</option>
          {
            clients.map((client) => (
              <option
                value={client.id}
                selected={quote.client_id === client.id}
                data-name={client.name}
                data-contact={client.contact ?? ''}
                data-phone={client.phone ?? ''}
              >
                {client.name}
              </option>
            ))
          }
        </select>
      </div>
      <div class="field">
        <label for="subject">報價主題</label>
        <input id="subject" name="subject" value={quote.subject ?? ''} required />
      </div>
      <div class="field">
        <label for="client_name">客戶名稱</label>
        <input id="client_name" name="client_name" value={quote.client_name ?? ''} required />
      </div>
      <div class="field">
        <label for="client_contact">聯絡人</label>
        <input id="client_contact" name="client_contact" value={quote.client_contact ?? ''} />
      </div>
      <div class="field">
        <label for="client_phone">客戶電話</label>
        <input id="client_phone" name="client_phone" value={quote.client_phone ?? ''} />
      </div>
      <div class="field">
        <label for="quote_date">報價日期</label>
        <input id="quote_date" name="quote_date" type="date" value={quote.quote_date ?? ''} required />
      </div>
      <div class="field">
        <label for="valid_until">有效期限</label>
        <input id="valid_until" name="valid_until" type="date" value={quote.valid_until ?? ''} />
      </div>
      <div class="field">
        <label for="tax_rate">稅率</label>
        <input id="tax_rate" name="tax_rate" type="number" min="0" max="1" step="0.01" value={quote.tax_rate} required />
      </div>
      <div class="field field--wide">
        <label for="notes">備註</label>
        <textarea id="notes" name="notes">{quote.notes ?? company.default_notes ?? ''}</textarea>
      </div>
    </section>

    <section>
      <div class="row-actions">
        <h2>品項</h2>
        <button class="button--ghost" type="button" data-add-item>＋</button>
      </div>
      <div data-items>
        {
          quote.items.map((item) => (
            <div class="item-row">
              <div class="field">
                <label>品項</label>
                <input name="item_name" value={item.name} required />
              </div>
              <div class="field">
                <label>說明</label>
                <input name="item_description" value={item.description ?? ''} />
              </div>
              <div class="field">
                <label>數量</label>
                <input name="item_qty" type="number" min="0" step="0.01" value={item.qty} required />
              </div>
              <div class="field">
                <label>單位</label>
                <input name="item_unit" value={item.unit ?? ''} />
              </div>
              <div class="field">
                <label>單價</label>
                <input name="item_unit_price" type="number" min="0" step="1" value={item.unit_price} required />
              </div>
              <button class="button--ghost" type="button" data-remove-item>×</button>
            </div>
          ))
        }
      </div>
    </section>

    <div class="row-actions">
      <button type="submit">{submitLabel}</button>
      {quote.id > 0 && <a class="button" href={`/q/${quote.id}`}>返回檢視</a>}
    </div>
  </form>

  <div class="preview-sticky">
    <QuoteDocument quote={quote} company={company} />
  </div>
</div>

<template data-item-template>
  <div class="item-row">
    <div class="field"><label>品項</label><input name="item_name" required /></div>
    <div class="field"><label>說明</label><input name="item_description" /></div>
    <div class="field"><label>數量</label><input name="item_qty" type="number" min="0" step="0.01" value="1" required /></div>
    <div class="field"><label>單位</label><input name="item_unit" value="式" /></div>
    <div class="field"><label>單價</label><input name="item_unit_price" type="number" min="0" step="1" value="0" required /></div>
    <button class="button--ghost" type="button" data-remove-item>×</button>
  </div>
</template>

<script>
  import '../client/quote-editor';
</script>
